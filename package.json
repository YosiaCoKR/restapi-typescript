{
  "name": "restapi-typescript",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc && cp .env dist/.env",
    "start": "node dist/app.js",
    "lint": "npx eslint ./src --ext .ts",
    "lint:fix": "npx eslint ./src --ext .ts --fix",
    "prepare": "husky",
    "check-types": "npx tsc --noEmit --pretty",
    "check-lint": "npx eslint ./src --ext .ts --ext .js --ext .jsx --ext .tsx",
    "check-format": "npx prettier . --check",
    "format": "npx prettier . --write"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx pretty-quick --staged ng lint ng test",
      "pre-push": "ng build --aot true"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/nodemon": "^1.19.6",
    "@types/typescript": "^0.4.29",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemon": "^3.1.14"
  }
}
